<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_category_form_hksf_delivery" model="ir.ui.view">
        <field name="name">product.category.form.hksf.delivery</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <!-- Append after the last group in the form sheet -->
            <xpath expr="//sheet" position="inside">
                <group string="HKSF Income Accounts">
                    <field name="property_rental_income_account_categ_id"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
