<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_return_move_collection_wizard_form" model="ir.ui.view">
        <field name="name">return.move.collection.wizard.form</field>
        <field name="model">return.move.collection.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Collection Return">
                <group>
                    <field name="picking_id" readonly="1"/>
                    <field name="scheduled_date_only"/>
                    <field name="transportation_method"/>
                </group>
                <separator string="Return Lines"/>
                <field name="line_ids">
                    <list editable="bottom">
                        <field name="product_id"/>
                        <field name="qty_done"/>
                        <field name="return_qty"/>
                    </list>
                </field>
                <footer>
                    <button name="action_create_return_picking" string="Create Return Picking"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_return_move_collection_form" model="ir.actions.act_window">
        <field name="name">Create Collection Return</field>
        <field name="res_model">return.move.collection.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Header-button action: passes active_id (the source delivery picking) -->
    <record id="action_return_move_collection_wizard" model="ir.actions.act_window">
        <field name="name">Create Collection Return</field>
        <field name="res_model">return.move.collection.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'active_id': active_id}</field>
    </record>

</odoo>
