<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Override the default SO report to use our custom paper format -->
        <record id="sale.action_report_saleorder" model="ir.actions.report">
            <field name="paperformat_id" ref="hksf_rental.hksf_rental_paper_format"/>
        </record>

        <!-- Dedicated Rental/Sales report action -->
        <record id="action_report_hksf_rental" model="ir.actions.report">
            <field name="name">Rental / Sales Quotation</field>
            <field name="model">sale.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hksf_rental.report_sale_rental</field>
            <field name="report_file">hksf_rental.report_sale_rental</field>
            <field name="print_report_name">
                (object.state in ('draft', 'sent') and 'Quotation - %s' % object.name) or 'Order - %s' % object.name
            </field>
            <field name="paperformat_id" ref="hksf_rental.hksf_rental_paper_format"/>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>
