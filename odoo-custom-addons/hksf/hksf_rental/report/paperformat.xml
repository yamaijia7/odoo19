<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hksf_rental_paper_format" model="report.paperformat">
            <field name="name">HKSF Rental Quote</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">85</field>
            <field name="margin_bottom">65</field>
            <field name="margin_left">3</field>
            <field name="margin_right">0</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">81</field>
            <field name="dpi">90</field>
        </record>

        <!-- Invoice paperformat: large top margin so the company / INVOICE /
             client header band (rendered in <div class="header">) has room to
             print on every page. Mirrors the Odoo 11 invoice paperformat
             (margin_top 100, header_spacing 90). -->
        <record id="hksf_rental_invoice_paper_format" model="report.paperformat">
            <field name="name">HKSF Rental Invoice</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">100</field>
            <field name="margin_bottom">28</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">90</field>
            <field name="dpi">90</field>
        </record>
    </data>
</odoo>
