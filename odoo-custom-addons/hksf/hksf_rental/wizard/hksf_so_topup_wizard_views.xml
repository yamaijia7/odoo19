<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hksf_so_topup_wizard_form" model="ir.ui.view">
        <field name="name">hksf.so.topup.wizard.form</field>
        <field name="model">hksf.so.topup.wizard</field>
        <field name="arch" type="xml">
            <form string="Top-up Delivery">
                <group>
                    <field name="order_id"/>
                    <field name="service_date"/>
                </group>
                <separator string="Lines"/>
                <field name="line_ids">
                    <list editable="bottom">
                        <field name="so_line_id" column_invisible="1"/>
                        <field name="is_new" column_invisible="1"/>
                        <field name="product_id"/>
                        <field name="current_qty" readonly="1"/>
                        <field name="price_unit" readonly="1"/>
                        <field name="product_uom_id" readonly="1"/>
                        <field name="additional_qty"/>
                        <field name="new_total_qty" readonly="1"/>
                    </list>
                </field>
                <footer>
                    <button name="action_apply" string="Apply &amp; Generate Delivery"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hksf_so_topup_wizard" model="ir.actions.act_window">
        <field name="name">Top-up Delivery</field>
        <field name="res_model">hksf.so.topup.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_order_id': active_id}</field>
    </record>

</odoo>
