<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_template_form_hksf_delivery" model="ir.ui.view">
        <field name="name">product.template.form.hksf.delivery</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']" position="after">
                <page string="HKSF Rental" name="hksf_rental_product">
                    <group string="Minimum Charge">
                        <field name="ia_apply_minimum_charge"/>
                    </group>
                    <group string="Income Accounts">
                        <field name="property_lost_account_income_id"/>
                        <field name="property_r_and_d_account_income_id"/>
                        <field name="property_rental_income_account_id"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
