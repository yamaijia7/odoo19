<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_delivery_return_history_list" model="ir.ui.view">
        <field name="name">delivery.return.history.list</field>
        <field name="model">delivery.return.history</field>
        <field name="arch" type="xml">
            <list string="Return History">
                <field name="deliver_move_id"/>
                <field name="return_move_id"/>
                <field name="return_qty"/>
                <field name="delivered_qty"/>
                <field name="deliver_invoice_line_id"/>
                <field name="return_invoice_line_id"/>
            </list>
        </field>
    </record>

    <record id="view_delivery_return_history_form" model="ir.ui.view">
        <field name="name">delivery.return.history.form</field>
        <field name="model">delivery.return.history</field>
        <field name="arch" type="xml">
            <form string="Return History">
                <group>
                    <field name="deliver_move_id"/>
                    <field name="return_move_id"/>
                    <field name="return_qty"/>
                    <field name="delivered_qty"/>
                    <field name="deliver_invoice_line_id"/>
                    <field name="return_invoice_line_id"/>
                </group>
            </form>
        </field>
    </record>

</odoo>
