<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Extend the main invoice form (account.move) to expose HKSF delivery
        billing fields on each invoice line.

        In Odoo 17+ invoice lines live inside account.view_move_form —
        there is no separate account.view_invoice_line_form.
        We extend the column optional header on the invoice_line_ids list.
    -->
    <record id="view_move_form_hksf_delivery_lines" model="ir.ui.view">
        <field name="name">account.move.form.hksf.delivery.lines</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Manual Invoice flag in the invoice header (Other Info area) -->
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="is_manual_invoice"/>
            </xpath>
            <!-- Default-visible columns on the invoice lines list, per user:
                 leave the CORE columns alone (Product, Label, Account, Analytic,
                 Quantity, Price, Amount keep their core defaults). We only force
                 the HKSF custom columns to hidden so they don't clutter the
                 default view. The user can still toggle anything on via the
                 column filter. These are per-user UI defaults only; they do not
                 affect the printed PDF. -->

            <!-- Add the HKSF custom columns after price_unit; ALL hidden by
                 default so the user's 4-column default is preserved. -->
            <xpath expr="//field[@name='invoice_line_ids']//field[@name='price_unit']"
                   position="after">
                <field name="custom_price_unit"   optional="hide" column_invisible="1"/>
                <field name="days"                optional="hide"/>
                <field name="custom_month"        optional="hide"/>
                <field name="start_date"          optional="hide"/>
                <field name="end_date"            optional="hide"/>
                <button name="%(action_manual_month_update_wizard)d"
                        string="Select Days"
                        type="action"
                        icon="fa-pencil-square-o"
                        column_invisible="not parent.is_manual_invoice"/>
                <field name="minimum_charge_days" optional="hide"/>
                <field name="is_from_previous_month" optional="hide"/>
                <field name="is_transport_product"   optional="hide"/>
                <field name="picking_id"          optional="hide"/>
                <field name="custom_move_id"      optional="hide"/>
                <field name="custom_sale_line_id" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>
