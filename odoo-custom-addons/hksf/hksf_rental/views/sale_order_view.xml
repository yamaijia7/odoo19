<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Rental invoice wizard action. Cog-menu binding REMOVED (v19.0.1.65.0):
         reached via the unified Create Invoice wizard (kind = Rental/Service),
         which delegates to this model. Record kept (no binding) for clarity. -->
    <record id="action_hksf_delivery_invoice_wizard" model="ir.actions.act_window">
        <field name="name">Create Rental Invoice</field>
        <field name="res_model">hksf.delivery.invoice.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ================================================================
         Sale Order Form — rental fields (from hksf_rental)
         Odoo 19: converted to direct attributes and list views
         ================================================================ -->
    <record id="view_sale_order_form_hksf_rental" model="ir.ui.view">
        <field name="name">sale.order.form.hksf.rental</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Hide Odoo's native Create Invoice from the HEADER only; it stays
                 available in the cog/Action menu (its bound action is left
                 intact). The unified dispatcher below replaces it in the header. -->
            <xpath expr="//button[@id='create_invoice']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@id='create_invoice_percentage']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Odoo's native invoice smart button (action_view_invoice) on RENTAL
                 orders only, where hksf_rental shows its own "Invoices" stat button
                 (action_view_delivery_invoice, which also aggregates child/linked-order
                 invoices). On non-rental orders the native button is kept, preserving the
                 stock "hide when no invoices" behaviour. Fixes the duplicate "Invoices"
                 smart button on rentals. -->
            <xpath expr="//button[@name='action_view_invoice']" position="attributes">
                <attribute name="invisible">custom_sale_type == 'rent' or invoice_count == 0</attribute>
            </xpath>

            <!-- Header buttons: unified Create Invoice + Print Quote + rental actions -->
            <xpath expr="//header" position="inside">
                <!-- Unified Create Invoice dispatcher (replaces the native header
                     button). Shown on confirmed orders of any sale type. -->
                <button name="%(action_hksf_create_invoice_wizard)d"
                        string="Create Invoice"
                        type="action"
                        class="btn-primary"
                        invisible="state not in ('sale', 'done')"/>
                <!-- Print-document chooser (Rental Quote / E&D Quote) -->
                <button name="%(action_hksf_print_report_wizard)d"
                        string="Print Quote"
                        type="action"
                        class="btn-secondary"/>
                <button name="%(action_collection_return_wizard)d"
                        string="Create Collection"
                        type="action"
                        class="btn-primary"
                        invisible="custom_sale_type != 'rent' or state not in ('sale', 'done')"/>
                <!-- Unified New Order launcher: merges the former "Top-up
                     Delivery" and "New Linked Order" header buttons. The
                     dispatcher (hksf.new.order.wizard) routes to the existing
                     top-up grid wizard or sale.order.action_new_linked_order().
                     Visibility = union of the two former buttons' conditions:
                       - Top-up: confirmed rental, not a child order
                       - Linked: confirmed (state 'sale'), not a child order
                     i.e. shown on a confirmed master order; the top-up branch
                     is guarded for non-rental inside the wizard. -->
                <button name="%(action_hksf_new_order_wizard)d"
                        string="New Order"
                        type="action"
                        class="btn-secondary"
                        invisible="state not in ('sale', 'done') or billing_master_id"/>
                <button name="action_pull_master_prices"
                        string="Pull Prices from Master"
                        type="object"
                        class="btn-secondary"
                        invisible="not billing_master_id or state not in ('draft', 'sent')"/>
            </xpath>

            <!-- Smart button: Invoices linked to this order (wizard + standard) -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_delivery_invoice"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-pencil-square-o"
                        invisible="custom_sale_type != 'rent'">
                    <field name="delivery_invoice_count" widget="statinfo" string="Invoices"/>
                </button>
                <button name="action_view_incoming_shipment"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-truck"
                        invisible="custom_sale_type != 'rent'">
                    <field name="incoming_shipment_count" widget="statinfo" string="Collections"/>
                </button>
                <!-- Linked Orders smart button (master) -->
                <button name="action_view_linked_orders"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-link"
                        invisible="linked_order_count == 0">
                    <field name="linked_order_count" widget="statinfo" string="Linked Orders"/>
                </button>
                <!-- Billing master smart button (child) -->
                <button name="action_view_billing_master"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-money"
                        invisible="not billing_master_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Billing via</span>
                        <field name="billing_master_id" class="o_stat_value" nolabel="1"/>
                    </div>
                </button>
            </xpath>

            <!-- Linked-order header fields: SP reference + billing master -->
            <xpath expr="//field[@name='partner_shipping_id']" position="before">
                <field name="sp_reference" readonly="1"/>
                <field name="billing_master_id" readonly="1"
                       invisible="not billing_master_id"/>
            </xpath>

            <!-- Sale Type + Subject after partner_shipping_id -->
            <xpath expr="//field[@name='partner_shipping_id']" position="after">
                <field name="custom_sale_type"/>
                <field name="charge_type"
                       invisible="custom_sale_type != 'rent'"/>
                <field name="minimum_charge_method"
                       invisible="custom_sale_type != 'rent'"/>
                <field name="is_manual_invoice"
                       invisible="custom_sale_type != 'rent'"/>
                <!-- Active-rental follow-up: state + closing-bill override -->
                <field name="rental_followup_state"
                       invisible="custom_sale_type != 'rent'"/>
                <field name="last_collection_date"
                       invisible="custom_sale_type != 'rent'"/>
                <field name="last_invoiced_through"
                       invisible="custom_sale_type != 'rent'"/>
                <field name="on_hire_qty"
                       invisible="custom_sale_type != 'rent'"/>
                <field name="rental_billing_closed"
                       invisible="custom_sale_type != 'rent'"/>
                <field name="subject_line"/>
            </xpath>

            <!-- Extra quotation fields after payment_term_id -->
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="subject_description"/>
                <field name="grand_total_label"/>
                <field name="custom_chop_and_sign"/>
                <field name="body_font_size"/>
                <field name="total_pages"/>
            </xpath>

            <!-- Salesperson signature after picking_policy -->
            <xpath expr="//field[@name='picking_policy']" position="after">
                <field name="sale_person_signature"/>
            </xpath>

            <!-- Order line list: add line_type before product_id -->
            <xpath expr="//list/field[@name='product_id']" position="before">
                <field name="line_type" optional="show"/>
            </xpath>

            <!-- Order line list: add rental period fields after product_id.
                 optional="show/hide" makes every column toggleable from the
                 column-settings (gear) menu on the order lines list. -->
            <xpath expr="//list/field[@name='product_id']" position="after">
                <field name="start_date" optional="hide"
                       column_invisible="parent.custom_sale_type != 'rent'"/>
                <field name="end_date" optional="hide"
                       column_invisible="parent.custom_sale_type != 'rent'"/>
                <field name="month" optional="hide"
                       column_invisible="parent.custom_sale_type != 'rent' or parent.is_manual_invoice"/>
                <!-- Manual Invoice columns (Odoo 11 manual_customer_invoice) -->
                <field name="custom_days" optional="show"
                       column_invisible="not parent.is_manual_invoice"/>
                <field name="custom_month" optional="show"
                       column_invisible="not parent.is_manual_invoice"/>
                <button name="%(action_manual_month_update_wizard)d"
                        string="Select Days"
                        type="action"
                        icon="fa-pencil-square-o"
                        column_invisible="not parent.is_manual_invoice"
                        invisible="parent.state not in ('draft', 'sent')"/>
            </xpath>

            <!-- Order line list: weight / volume after product_uom_qty.
                 Unit columns => Wt / Vol; subtotal columns => Sub. Wt / Sub. Vol.
                 All toggleable from the column-settings (gear) menu. -->
            <xpath expr="//list/field[@name='product_uom_qty']" position="after">
                <field name="weight" string="Wt" optional="hide"/>
                <field name="subtotal_weight" string="Sub. Wt" optional="hide"/>
                <field name="volume" string="Vol" optional="hide"/>
                <field name="subtotal_volume" string="Sub. Vol" optional="hide"/>
                <!-- Service order lines: tick "Bill" to bill this service-type
                     line's remaining qty on the next rental invoice. The
                     checkbox is only meaningful for service products, so the
                     column is hidden for non-service lines (rental / sale
                     lines) and the monthly rental proration is never affected.
                     class="text-center" centres both the header and the boolean
                     glyph in the cell. -->
                <field name="is_service_line" column_invisible="1"/>
                <field name="bill_on_next_invoice" string="Bill"
                       class="text-center"
                       readonly="not is_service_line"
                       invisible="not is_service_line"
                       optional="show"/>
            </xpath>

            <!-- NOTE (v19.0.1.74.0): we do NOT add a qty_invoiced column here.
                 The base sale Order Lines list already renders the native
                 qty_invoiced ("Invoiced") column (after "Delivered"). The
                 round-6 view added a SECOND qty_invoiced column next to "Bill",
                 which produced a duplicate "Invoiced" header. That added column
                 was removed; the single native column is the source of truth and
                 is fed by the wizard's sale_line_ids link on service invoice
                 lines. (Custom service_invoiced_qty / service_to_invoice_qty
                 mirror columns were already removed in v19.0.1.73.0.) -->

            <!-- Order line form: add rental fields after product_id in form -->
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="line_type"/>
                <field name="start_date"
                       invisible="line_type == 'sale'"/>
                <field name="end_date"
                       invisible="line_type == 'sale'"/>
                <field name="month"
                       invisible="line_type == 'sale'"/>
                <field name="weight"/>
                <field name="subtotal_weight"/>
                <field name="volume"/>
                <field name="subtotal_volume"/>
            </xpath>

            <!-- Weight/volume totals panel at order level.
                 Short labels (Wt / Vol) with the unit shown via the field's
                 own widget; no extra span (the old span overlapped the value). -->
            <xpath expr="//group[hasclass('oe_subtotal_footer')]" position="after">
                <group string="Weight / Volume Totals">
                    <field name="total_weight" string="Wt" widget="float"
                           options="{'digits': [16, 2]}"/>
                    <field name="total_volume" string="Vol" widget="float"
                           options="{'digits': [16, 2]}"/>
                </group>
            </xpath>

        </field>
    </record>

    <!-- ================================================================
         Sale Order Form — delivery/invoicing fields (from hksf_delivery_invoice)
         ================================================================ -->
    <record id="view_sale_order_form_hksf_delivery" model="ir.ui.view">
        <field name="name">sale.order.form.hksf.delivery</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Pricelists in Other Info tab. The Reload button sits on the
                 right of the pricelist fields (two side-by-side sub-groups):
                 prices are static to the SO and this re-pulls them on demand. -->
            <xpath expr="//page[@name='other_information']" position="inside">
                <group string="Rental Pricelists">
                    <group>
                        <field name="repair_pricelist_id"/>
                        <field name="lost_pricelist_id"/>
                    </group>
                    <group>
                        <button name="action_reload_rd_prices"
                                string="Reload Price Lists"
                                type="object"
                                class="btn-secondary"/>
                    </group>
                </group>
            </xpath>

            <!-- New notebook pages -->
            <xpath expr="//notebook" position="inside">

                <page string="Outstanding Products" name="product_outstanding">
                    <button name="action_compute_outstanding_products"
                            string="Compute Outstanding"
                            type="object"
                            class="btn-secondary mb8"/>
                    <!-- Lost Material invoicing now lives in the unified Create
                         Invoice wizard (header -> Create Invoice -> kind = Lost
                         Material), which auto-runs Compute Outstanding first.
                         The page button was removed to reduce clutter; the
                         underlying action_outstanding_create_lost_invoice is
                         still called by that wizard. -->
                    <!-- Qty columns forced to 0 decimals on THIS page only via
                         options digits=[16,0] (does not change global UoM
                         precision). 'Balance' = delivered - collected. Unit
                         Price now pulls the stamped lost price (see model). -->
                    <field name="product_outstanding_ids">
                        <list>
                            <field name="product_id"/>
                            <field name="uom_id" string="UoM"/>
                            <field name="delivered_qty"
                                   options="{'digits': [16, 0]}"/>
                            <field name="collected_qty"
                                   options="{'digits': [16, 0]}"/>
                            <field name="lost_products_qty" string="Balance"
                                   options="{'digits': [16, 0]}"/>
                            <field name="price_unit"
                                   options="{'digits': [16, 2]}"/>
                        </list>
                    </field>
                </page>

                <!-- NOTE: the "Lost / Damaged Materials" page was retired in
                     v19.0.1.27.0. The collection.repair.damage model, the
                     collection_lost_material_ids field, action_compute_lost_product
                     and action_create_lost_product_invoice are ALL KEPT; only the
                     UI entry point moved to the Outstanding Products page above.
                     No data is dropped. -->

                <!-- NOTE (v19.0.1.70.0): the round-2 "Service Lines" page +
                     "Pull Invoiceable Service Lines" button were REMOVED.
                     Service billing is now driven by the per-order-line
                     "Bill on Next Invoice" checkbox in the Order Lines list
                     above. The service.charge model + billing plumbing are
                     retained for historical data; the wizard now feeds service
                     billing from the checkbox instead of service.charge rows. -->

            </xpath>

        </field>
    </record>

    <!-- Repair/Damage wizard action. Cog-menu binding REMOVED (v19.0.1.65.0):
         reached via the unified Create Invoice wizard (kind = Repair + Damage),
         which delegates to this model. Record kept (no binding) for clarity. -->
    <record id="action_damage_lost_invoice_wizard" model="ir.actions.act_window">
        <field name="name">Create Repair / Damage Invoice</field>
        <field name="res_model">damage.lost.invoice.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ================================================================
         Sale Order List/Tree — add SP Reference column
         ================================================================ -->
    <record id="view_sale_order_tree_hksf_rental" model="ir.ui.view">
        <field name="name">sale.order.list.hksf.rental</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="sp_reference" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Sale Line Qty Update Wizard action -->
    <record id="action_sale_line_qty_update_wizard" model="ir.actions.act_window">
        <field name="name">Update Ordered Quantities</field>
        <field name="res_model">sale.line.qty.update.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_view_types">form</field>
    </record>

    <!-- ================================================================
         Active Rentals — monthly follow-up worklist
         Native filter + dedicated action/menu under "To Invoice",
         mirroring "Orders to Invoice" / "Orders to Upsell".
         ================================================================ -->
    <record id="view_sale_order_filter_active_rentals" model="ir.ui.view">
        <field name="name">sale.order.search.active.rentals</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_view_search_inherit_sale"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter name="active_rentals"
                        string="Active Rentals"
                        domain="[('is_active_rental','=',True)]"
                        help="Confirmed rentals with equipment still on site"/>
                <filter name="group_active_customer"
                        string="Customer"
                        context="{'group_by':'partner_id'}"/>
            </xpath>
        </field>
    </record>

    <!-- Dedicated list for the worklist: shows the follow-up state, on-hire
         qty and billing-coverage dates, and highlights rentals whose closing
         invoice is still owed (final_bill_due). PRIMARY (not an inherit) so
         these rental-only columns never leak into other sale.order lists. -->
    <record id="view_active_rentals_list" model="ir.ui.view">
        <field name="name">sale.order.list.active.rentals</field>
        <field name="model">sale.order</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <list string="Active Rentals"
                  decoration-warning="rental_followup_state == 'final_bill_due'"
                  decoration-muted="rental_followup_state == 'done'">
                <field name="name"/>
                <field name="sp_reference" optional="show"/>
                <field name="partner_id"/>
                <field name="date_order" optional="hide"/>
                <field name="rental_followup_state" widget="badge"
                       decoration-info="rental_followup_state == 'on_hire'"
                       decoration-warning="rental_followup_state == 'final_bill_due'"/>
                <field name="on_hire_qty" sum="On Hire"/>
                <field name="last_collection_date"/>
                <field name="last_invoiced_through"/>
                <field name="amount_total" sum="Total" optional="show"/>
            </list>
        </field>
    </record>

    <record id="action_active_rentals" model="ir.actions.act_window">
        <field name="name">Active Rentals</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('is_active_rental','=',True)]</field>
        <field name="context">{'search_default_group_active_customer': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No active rentals</p>
            <p>Confirmed rentals needing follow-up appear here: equipment still
               on site (On Hire), OR fully collected but the closing invoice is
               not yet billed up to the last collection date (Final Bill Due).
               Orders drop off only once both gates clear (or 'Rental Billing
               Closed' is ticked).</p>
        </field>
    </record>

    <!-- Bind the dedicated list to the action (keep kanban + form too). -->
    <record id="action_active_rentals_list_view" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_active_rentals_list"/>
        <field name="act_window_id" ref="action_active_rentals"/>
    </record>

    <menuitem id="menu_active_rentals"
              name="Active Rentals"
              parent="sale.menu_sale_invoicing"
              action="action_active_rentals"
              sequence="15"/>

    <!-- ================================================================
         Exclude RENTAL orders from the native "Orders to Invoice" and
         "Orders to Upsell" lists. Rentals are billed via the dedicated
         Active Rentals worklist + rental invoice wizard, not Odoo's native
         per-order invoicing, so they are noise here. We only EXTEND the
         native domain (add custom_sale_type != 'rent'); behaviour for
         'sale'-type orders is unchanged.
         ================================================================ -->
    <!-- NOTE: custom_sale_type is a non-required stored Selection (default
         'rent') with no backfill migration, so legacy/blank orders may be
         NULL. A bare ('custom_sale_type','!=','rent') would ALSO drop NULL
         rows in Postgres (NULL != 'rent' is not TRUE), wrongly hiding old
         'sale'-type orders. The OR below hides ONLY true rentals and keeps
         'sale' AND NULL orders visible. -->
    <record id="sale.action_orders_to_invoice" model="ir.actions.act_window">
        <field name="domain">['&amp;', ('invoice_status', '=', 'to invoice'), '|', ('custom_sale_type', '!=', 'rent'), ('custom_sale_type', '=', False)]</field>
    </record>

    <record id="sale.action_orders_upselling" model="ir.actions.act_window">
        <field name="domain">['&amp;', ('invoice_status', '=', 'upselling'), '|', ('custom_sale_type', '!=', 'rent'), ('custom_sale_type', '=', False)]</field>
    </record>

</odoo>
