<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Intentionally minimal.
         The "Default Line Type" (line_type) field used to be injected here,
         beside the product name. It has been moved into the "HKSF Rental"
         notebook page (see product_view.xml) so all rental settings live in
         one place. This record is retained (empty arch no-op) so the upgrade
         cleanly drops the old beside-the-title placement without leaving a
         dangling view id. -->
    <record id="product_template_form_hksf_rental" model="ir.ui.view">
        <field name="name">product.template.form.hksf.rental</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <data/>
        </field>
    </record>
</odoo>
