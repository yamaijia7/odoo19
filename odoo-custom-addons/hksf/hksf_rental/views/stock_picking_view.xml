<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit stock.picking form view -->
    <record id="view_picking_form_hksf_delivery" model="ir.ui.view">
        <field name="name">stock.picking.form.hksf.delivery</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <!-- Inline Repair / Damage qty columns on the collection move lines,
                 right after the Demand column. Visible ONLY on incoming
                 (collection) pickings so they don't leak onto deliveries or
                 other modules' pickings. -->
            <xpath expr="//field[@name='move_ids']/list/field[@name='product_uom_qty']" position="after">
                <field name="repair_qty"
                       string="Repair"
                       optional="show"
                       column_invisible="parent.picking_type_code != 'incoming'"/>
                <field name="damage_qty"
                       string="Damage"
                       optional="show"
                       column_invisible="parent.picking_type_code != 'incoming'"/>
            </xpath>

            <!-- Header button: assign return quantities (on done collections).
                 NOTE: the order-level "Create Collection" button lives on the
                 sale order form (see views/sale_order_view.xml), matching the
                 Odoo 11 collection_create_from_so flow. -->
            <xpath expr="//header" position="inside">
                <button name="%(action_return_move_select_wizard)d"
                        type="action"
                        string="Assign Return Qty"
                        invisible="picking_type_code != 'incoming' or state != 'done'"/>
                <!-- ONE merged button: re-syncs BOTH the rental return credit
                     (after the collected/Done qty was corrected) AND the
                     Repair/Damage lines (from the inline columns). Idempotent;
                     edit the Done qty first, then press this. -->
                <button name="action_sync_collection"
                        type="object"
                        string="Sync Collection"
                        invisible="picking_type_code != 'incoming' or state != 'done'"/>
            </xpath>

            <!-- Service Date (date-only) — after date_deadline. The core
                 datetime field is "Scheduled Date"; this is the date-only
                 mirror used for invoice date-range comparisons. -->
            <xpath expr="//field[@name='date_deadline']" position="after">
                <field name="scheduled_date_only" required="1"/>
            </xpath>

            <!-- Custom fields in a new notebook page -->
            <xpath expr="//notebook" position="inside">
                <page string="Delivery Info" name="hksf_delivery_info">
                    <group>
                        <group string="Logistics">
                            <field name="delivery_type"/>
                            <field name="transportation_method"/>
                            <field name="license_plate"/>
                            <field name="truck_size_id"
                                   options="{'no_quick_create': False}"/>
                            <field name="custom_employee_id"/>
                            <field name="time_in"/>
                            <field name="time_out"/>
                        </group>
                        <!-- Invoice group: every field here is written by the
                             billing wizards / computed. Each field is marked
                             readonly="1" individually to prevent accidental
                             hand-edits that would desync billing.
                             NOTE: in Odoo 19's OWL compiler, readonly on a
                             <group> is NOT propagated to child fields (the
                             group meta-attrs invisible/readonly/required are
                             skipped in compileGenericNode), so it MUST be set
                             per field, not on the group. -->
                        <group string="Invoice">
                            <field name="invoice_id" readonly="1"/>
                            <field name="last_invoice_date" readonly="1"/>
                            <field name="is_create_transport_invoice" invisible="1"/>
                            <field name="is_from_previous_month" readonly="1"/>
                            <field name="custom_sale_order_id" readonly="1"/>
                            <field name="partner_parent_id" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Site Contacts"/>
                    <field name="site_contact_ids" widget="many2many_tags"/>
                    <separator string="Transport Charges"/>
                    <field name="transport_charge_ids">
                        <list editable="bottom">
                            <field name="product_id"/>
                            <field name="name"/>
                            <field name="product_uom_qty"/>
                            <field name="product_uom"/>
                            <field name="price_unit"/>
                            <field name="invoice_id"/>
                            <field name="is_create_transport_invoice" column_invisible="True"/>
                        </list>
                    </field>
                    <!-- Repair / Damage billables only exist on incoming
                         (collection) pickings; hide on outgoing deliveries. -->
                    <separator string="Repair / Damage"
                               invisible="picking_type_code != 'incoming'"/>
                    <field name="collection_repair_ids"
                           invisible="picking_type_code != 'incoming'">
                        <list editable="bottom">
                            <field name="product_id"/>
                            <field name="internal_ref"/>
                            <field name="qty"/>
                            <field name="type"/>
                            <field name="price_unit"/>
                            <field name="invoice_id"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

    <!-- Add the date-only "Service Date" column to the standard transfers
         list (stock.vpicktree). Placed after the native "Scheduled Date"
         column. optional="show" => visible by default, user-toggleable via
         the column options menu. Global (Option A): appears on all transfers;
         it is simply blank on non-rental pickings that never set it. -->
    <record id="vpicktree_hksf_service_date" model="ir.ui.view">
        <field name="name">stock.picking.list.hksf.service.date</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='scheduled_date']" position="after">
                <field name="scheduled_date_only"
                       string="Service Date"
                       optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Add "Service Date" to the transfers search view: enables
         search-as-you-type on the field plus a Group By entry. -->
    <record id="view_picking_search_hksf_service_date" model="ir.ui.view">
        <field name="name">stock.picking.search.hksf.service.date</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_internal_search"/>
        <field name="arch" type="xml">
            <!-- Searchable field (type a date to filter). -->
            <xpath expr="//field[@name='name']" position="after">
                <field name="scheduled_date_only" string="Service Date"/>
            </xpath>
            <!-- Group By -> Service Date entry. Anchored after the existing
                 Status group-by filter if present, else appended to filters. -->
            <xpath expr="//group" position="inside">
                <filter name="group_by_service_date"
                        string="Service Date"
                        context="{'group_by': 'scheduled_date_only'}"/>
            </xpath>
        </field>
    </record>

</odoo>
