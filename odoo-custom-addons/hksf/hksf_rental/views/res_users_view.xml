<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_users_form_hksf_rental" model="ir.ui.view">
        <field name="name">res.users.form.hksf.rental</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='signature']" position="after">
                <field name="signature_custom" widget="image"/>
                <field name="sp_code"/>
            </xpath>
        </field>
    </record>
</odoo>
