<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="hr_payslip_form_hkssl" model="ir.ui.view">
    <field name="name">hr.payslip.form.hkssl</field>
    <field name="model">hr.payslip</field>
    <field name="inherit_id" ref="payroll.hr_payslip_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//div[@name='button_box']" position="inside">
        <button class="oe_stat_button" type="object"
                name="show_paid_timesheetline" icon="fa-tasks">
          <field name="timesheet_line_count" string="Timesheets" widget="statinfo"/>
        </button>
      </xpath>
      <xpath expr="//notebook" position="inside">
        <page name="timesheet_lines" string="Timesheet Lines">
          <field name="timesheet_ids" readonly="1">
            <list>
              <field name="date"/><field name="name"/>
              <field name="work_type_id"/>
              <field name="hour_days" widget="float_time"/>
              <field name="days"/>
              <field name="amount" string="Wage Cost"/>
              <field name="is_payroll_paid"/>
            </list>
          </field>
        </page>
        <page name="work_type_summary" string="Work Type Summary">
          <!-- OCA-NATIVE: read the engine's own worked-days lines (one per
               work-type code) instead of the retired payslip.totalhour. -->
          <field name="worked_days_line_ids" nolabel="1" readonly="1">
            <list>
              <field name="code"/>
              <field name="name"/>
              <field name="number_of_days"/>
              <field name="number_of_hours" widget="float_time"/>
            </list>
          </field>
        </page>
      </xpath>
    </field>
  </record>
</odoo>
