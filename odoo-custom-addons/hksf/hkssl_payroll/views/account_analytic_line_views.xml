<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_analytic_line_timesheet_payroll_list" model="ir.ui.view">
        <field name="name">account.analytic.line.timesheet.payroll.list</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.hr_timesheet_line_tree"/>
        <field name="arch" type="xml">
            <field name="date" position="after">
                <field name="work_type_id" optional="show"/>
                <field name="days" optional="show"/>
                <field name="hour_days" optional="show"/>
            </field>
            <field name="unit_amount" position="after">
                <field name="amount" string="Wage Cost" optional="show" readonly="1"/>
                <field name="is_payroll_paid" optional="show"/>
                <field name="custom_payslip_id" optional="show" readonly="1"/>
            </field>
        </field>
    </record>
    <record id="view_analytic_line_timesheet_payroll_form" model="ir.ui.view">
        <field name="name">account.analytic.line.timesheet.payroll.form</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.hr_timesheet_line_form"/>
        <field name="arch" type="xml">
            <field name="unit_amount" position="before">
                <field name="work_type_id"/>
                <field name="days"/>
                <field name="hour_days"/>
            </field>
            <field name="unit_amount" position="after">
                <field name="is_payroll_paid" readonly="1"/>
                <field name="custom_payslip_id" readonly="1"/>
            </field>
        </field>
    </record>
    <record id="action_paid_analytic_line" model="ir.actions.act_window">
        <field name="name">Paid Timesheet Lines</field>
        <field name="res_model">account.analytic.line</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_payroll_paid', '=', True)]</field>
    </record>
</odoo>
