<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="timesheet_work_type_form" model="ir.ui.view">
    <field name="name">timesheet.work.type.form</field>
    <field name="model">timesheet.work.type</field>
    <field name="arch" type="xml">
      <form string="Work Type"><sheet><group><group>
        <field name="name"/><field name="code"/>
        <field name="sequence"/><field name="active"/>
      </group><group>
        <field name="r_factor"/><field name="dr_factor"/>
      </group></group></sheet></form>
    </field>
  </record>
  <record id="timesheet_work_type_list" model="ir.ui.view">
    <field name="name">timesheet.work.type.list</field>
    <field name="model">timesheet.work.type</field>
    <field name="arch" type="xml">
      <list>
        <field name="sequence" widget="handle"/>
        <field name="name"/><field name="code"/>
        <field name="r_factor"/><field name="dr_factor"/><field name="active"/>
      </list>
    </field>
  </record>
  <record id="action_timesheet_work_type" model="ir.actions.act_window">
    <field name="name">Work Types</field>
    <field name="res_model">timesheet.work.type</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
