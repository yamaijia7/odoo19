<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <!-- HK MPF Industry Scheme daily contribution scale (current MPFA figures).
         Daily relevant income min $280 / max $1,000; cap $50 each.
         Source: https://www.mpfa.org.hk/en/mpf-system/types-of-mpf-schemes/industry-schemes -->
    <record id="industry_scheme_default" model="payroll.industry.scheme">
      <field name="name">HK Industry Scheme (Daily)</field>
      <field name="active">True</field>
    </record>

    <record id="scheme_line_1" model="payroll.industry.scheme.line">
      <field name="scheme_id" ref="industry_scheme_default"/>
      <field name="name">Less than $280</field>
      <field name="from_amount">0.0</field><field name="to_amount">280</field>
      <field name="amount_payable_employer">10</field>
      <field name="amount_payable_employee">0.0</field>
    </record>
    <record id="scheme_line_2" model="payroll.industry.scheme.line">
      <field name="scheme_id" ref="industry_scheme_default"/>
      <field name="name">$280 to less than $350</field>
      <field name="from_amount">280</field><field name="to_amount">350</field>
      <field name="amount_payable_employer">15</field>
      <field name="amount_payable_employee">15</field>
    </record>
    <record id="scheme_line_3" model="payroll.industry.scheme.line">
      <field name="scheme_id" ref="industry_scheme_default"/>
      <field name="name">$350 to less than $450</field>
      <field name="from_amount">350</field><field name="to_amount">450</field>
      <field name="amount_payable_employer">20</field>
      <field name="amount_payable_employee">20</field>
    </record>
    <record id="scheme_line_4" model="payroll.industry.scheme.line">
      <field name="scheme_id" ref="industry_scheme_default"/>
      <field name="name">$450 to less than $550</field>
      <field name="from_amount">450</field><field name="to_amount">550</field>
      <field name="amount_payable_employer">25</field>
      <field name="amount_payable_employee">25</field>
    </record>
    <record id="scheme_line_5" model="payroll.industry.scheme.line">
      <field name="scheme_id" ref="industry_scheme_default"/>
      <field name="name">$550 to less than $650</field>
      <field name="from_amount">550</field><field name="to_amount">650</field>
      <field name="amount_payable_employer">30</field>
      <field name="amount_payable_employee">30</field>
    </record>
    <record id="scheme_line_6" model="payroll.industry.scheme.line">
      <field name="scheme_id" ref="industry_scheme_default"/>
      <field name="name">$650 to less than $750</field>
      <field name="from_amount">650</field><field name="to_amount">750</field>
      <field name="amount_payable_employer">35</field>
      <field name="amount_payable_employee">35</field>
    </record>
    <record id="scheme_line_7" model="payroll.industry.scheme.line">
      <field name="scheme_id" ref="industry_scheme_default"/>
      <field name="name">$750 to less than $850</field>
      <field name="from_amount">750</field><field name="to_amount">850</field>
      <field name="amount_payable_employer">40</field>
      <field name="amount_payable_employee">40</field>
    </record>
    <record id="scheme_line_8" model="payroll.industry.scheme.line">
      <field name="scheme_id" ref="industry_scheme_default"/>
      <field name="name">$850 to less than $950</field>
      <field name="from_amount">850</field><field name="to_amount">950</field>
      <field name="amount_payable_employer">45</field>
      <field name="amount_payable_employee">45</field>
    </record>
    <record id="scheme_line_9" model="payroll.industry.scheme.line">
      <field name="scheme_id" ref="industry_scheme_default"/>
      <field name="name">$950 or more (cap)</field>
      <field name="from_amount">950</field><field name="to_amount">100000</field>
      <field name="amount_payable_employer">50</field>
      <field name="amount_payable_employee">50</field>
    </record>
  </data>
</odoo>
