<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <!-- OCA-NATIVE REFACTOR (2026-06-21)
         Work-type pay is now driven by the native worked-days dict
         (worked_days.<CODE>) populated by hr_payslip.get_worked_day_lines(),
         multiplied by the per-contract rate from contract.worktype via
         contract.get_worktype_rate(code). The engine multiplies
         result * result_qty * (result_rate/100), so the payslip line shows
         quantity (days/hours) and rate (HKD) natively.

         RGL  = daily_rate  x worked days
         OT   = hourly rate x overtime hours
         OVRN = hourly rate x overnight hours

         OCA payroll's hr.salary.rule has no struct_id field; rules are linked
         to the structure via hr.payroll.structure.rule_ids (salary_structure.xml).
         MPF amounts are rounded to whole dollars inside the Python compute. -->

    <record id="hr_rule_rgl" model="hr.salary.rule">
      <field name="name">Regular Pay</field><field name="sequence" eval="10"/>
      <field name="code">RGL</field>
      <field name="category_id" ref="hkssl_payroll.BASIC"/>
      <field name="condition_select">python</field>
      <field name="condition_python">result = bool(worked_days.RGL and worked_days.RGL.number_of_days &gt; 0.0)</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute">daily_rate, hourly_rate = contract.get_worktype_rate('RGL')
result = daily_rate
result_qty = worked_days.RGL.number_of_days if worked_days.RGL else 0.0</field>
      <field name="appears_on_payslip" eval="True"/>
    </record>

    <record id="hr_rule_ot" model="hr.salary.rule">
      <field name="name">Overtime Pay</field><field name="sequence" eval="20"/>
      <field name="code">OT</field>
      <field name="category_id" ref="hkssl_payroll.BASIC"/>
      <field name="condition_select">python</field>
      <field name="condition_python">result = bool(worked_days.OT and worked_days.OT.number_of_hours &gt; 0.0)</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute">daily_rate, hourly_rate = contract.get_worktype_rate('OT')
result = hourly_rate
result_qty = worked_days.OT.number_of_hours if worked_days.OT else 0.0</field>
      <field name="appears_on_payslip" eval="True"/>
    </record>

    <record id="hr_rule_ovrn" model="hr.salary.rule">
      <field name="name">Overnight Pay</field><field name="sequence" eval="30"/>
      <field name="code">OVRN</field>
      <field name="category_id" ref="hkssl_payroll.BASIC"/>
      <field name="condition_select">python</field>
      <field name="condition_python">result = bool(worked_days.OVRN and worked_days.OVRN.number_of_hours &gt; 0.0)</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute">daily_rate, hourly_rate = contract.get_worktype_rate('OVRN')
result = hourly_rate
result_qty = worked_days.OVRN.number_of_hours if worked_days.OVRN else 0.0</field>
      <field name="appears_on_payslip" eval="True"/>
    </record>

    <record id="hr_rule_gross" model="hr.salary.rule">
      <field name="name">Gross</field><field name="sequence" eval="100"/>
      <field name="code">GROSS</field>
      <field name="category_id" ref="hkssl_payroll.GROSS"/><field name="condition_select">none</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute">result = categories.BASIC</field>
      <field name="appears_on_payslip" eval="True"/>
    </record>

    <record id="hr_rule_mpf_ee" model="hr.salary.rule">
      <field name="name">MPF Employee Contribution</field><field name="sequence" eval="110"/>
      <field name="code">MPF_EE</field>
      <field name="category_id" ref="hkssl_payroll.DED"/><field name="condition_select">none</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute">result = -employee._get_mpf_employee_contribution(categories.GROSS, payslip.date_from, payslip.date_to)</field>
      <field name="appears_on_payslip" eval="True"/>
    </record>

    <record id="hr_rule_mpf_er" model="hr.salary.rule">
      <field name="name">MPF Employer Contribution</field><field name="sequence" eval="111"/>
      <field name="code">MPF_ER</field>
      <field name="category_id" ref="hkssl_payroll.COMP"/><field name="condition_select">none</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute">result = employee._get_mpf_employer_contribution(categories.GROSS, payslip.date_from, payslip.date_to)</field>
      <field name="appears_on_payslip" eval="True"/>
    </record>

    <record id="hr_rule_expenserem" model="hr.salary.rule">
      <field name="name">Employee Expense Reimburse</field><field name="sequence" eval="116"/>
      <field name="code">EXPENSEREM</field>
      <field name="category_id" ref="hkssl_payroll.REIMBURSE"/>
      <field name="condition_select">python</field>
      <field name="condition_python">result = bool(inputs.EXPENSEREM and inputs.EXPENSEREM.amount)</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute">result = inputs.EXPENSEREM.amount if inputs.EXPENSEREM else 0.0</field>
      <field name="appears_on_payslip" eval="True"/>
    </record>

    <record id="hr_rule_expense" model="hr.salary.rule">
      <field name="name">Employee Expense Deduction</field><field name="sequence" eval="117"/>
      <field name="code">EXPENSE</field>
      <field name="category_id" ref="hkssl_payroll.DED"/>
      <field name="condition_select">python</field>
      <field name="condition_python">result = bool(inputs.EXPENSE and inputs.EXPENSE.amount)</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute">result = -inputs.EXPENSE.amount if inputs.EXPENSE else 0.0</field>
      <field name="appears_on_payslip" eval="True"/>
    </record>

    <record id="hr_rule_net" model="hr.salary.rule">
      <field name="name">Net Salary</field><field name="sequence" eval="200"/>
      <field name="code">NET</field>
      <field name="category_id" ref="hkssl_payroll.NET"/><field name="condition_select">none</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute">result = categories.GROSS + categories.REIMBURSE - categories.DED</field>
      <field name="appears_on_payslip" eval="True"/>
    </record>
  </data>
</odoo>
